# Model
MODEL_PATH=/app/models/gemma-3-4b-it/gemma-3-4b-it-Q4_K_M.gguf
MMPROJ_PATH=/app/models/gemma-3-4b-it/mmproj-model-f16.gguf

# Server
LLAMA_API_PORT=8080       # llama.cpp backend
FASTAPI_PORT=8000         # FastAPI + Web UI

# GPU: all layers on GPU (Gemma 3 has 32 layers)
GPU_LAYERS=32

# Context size: 4096 tokens (fits in 4GB VRAM with model)
CONTEXT_SIZE=4096

# Single worker
WORKERS=1
BATCH_SIZE=512

# System prompt (optional — defaults embedded in code)
# SYSTEM_PROMPT=Your custom system prompt here

# Job storage path (persists across restarts)
# JOBS_DIR=/app/jobs

# Image validation
MAX_IMAGE_SIZE_MB=16
MAX_IMAGE_DIMENSION=16384

# Llama-server health monitor
LLAMA_HEALTH_INTERVAL=15
LLAMA_MAX_RESTARTS=5

# Log rotation
LOG_FILE=./logs/server.log
LOG_MAX_BYTES=10485760       # 10 MB
LOG_BACKUP_COUNT=5
